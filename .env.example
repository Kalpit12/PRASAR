# Copy to .env and set DATABASE_URL (see Supabase Project Settings → Database).
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@YOUR_REGION.pooler.supabase.com:6543/postgres

# Postmark (optional) — transactional email; same vars as AksharJobs.
# POSTMARK_API_KEY=
# POSTMARK_SENDER_EMAIL=noreply@your-verified-domain.com
# POSTMARK_SENDER_NAME=PRASAR
# Optional: POSTMARK_REPLY_TO=  POSTMARK_MESSAGE_STREAM=outbound

# Public site URL (for BAPS logo in invitation HTML: …/local-app/BAPS.png). On Render, RENDER_EXTERNAL_URL is used if this is unset.
# PUBLIC_APP_URL=https://prasar.onrender.com

# Security (optional)
# NODE_ENV=production
# ALLOWED_ORIGINS=https://your-app.onrender.com
# PRASAR_TRUST_SAME_ORIGIN_WITHOUT_KEY=0
# PRASAR_EMAIL_RATE_LIMIT_PER_HOUR=30
# PRASAR_API_RATE_LIMIT_MAX=500
# PRASAR_BACKUP_HTTP_TOKEN=long-random-secret
# TRUST_PROXY=1
